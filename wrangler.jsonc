{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aura-app",
  "compatibility_date": "2026-04-08",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npx expo export -p web"
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
